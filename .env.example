# caliban-ai/docker-compose — environment
# Copy to `.env` (gitignored) and edit:  cp .env.example .env
# `.env` is read automatically by `docker compose`.

# ─────────────────────────────────────────────────────────────────────────────
# Image versions (pinned)
# ─────────────────────────────────────────────────────────────────────────────
# Pin to published GHCR release tags. For reproducible deploys you may pin by
# digest instead, e.g. GONZALO_VERSION=0.1.0@sha256:...  (hardened option).
#
# NOTE: the caliban image is an UPSTREAM PREREQUISITE — `ghcr.io/caliban-ai/
# caliban` must be published before the `caliban` service can pull. Set
# CALIBAN_VERSION to the first published release tag once it exists.
CALIBAN_VERSION=0.4.0
GONZALO_VERSION=0.1.0
PROSPERO_VERSION=0.1.0

# ─────────────────────────────────────────────────────────────────────────────
# Model provider credentials (caliban)
# ─────────────────────────────────────────────────────────────────────────────
# Default provider: Anthropic. Supply your key here for the `.env` path.
# (For a hardened deployment, leave this blank and use the secrets overlay:
#  docker compose -f compose.yaml -f overlays/secrets.yaml up)
ANTHROPIC_API_KEY=

# Other providers are passed through if you set them (uncomment as needed):
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=
# CALIBAN_LIVE_BEDROCK=1
# CALIBAN_LIVE_VERTEX=1
# GOOGLE_APPLICATION_CREDENTIALS=/run/gcp/creds.json

# ─────────────────────────────────────────────────────────────────────────────
# Base stack
# ─────────────────────────────────────────────────────────────────────────────
# Host port the prospero dashboard is published on.
PROSPERO_HTTP_PORT=7878

# Host directory caliban supervises, mounted into BOTH caliban and prospero at
# the same in-container path (/workspace) so socket discovery matches. Must be a
# real directory (no symlink surprises). Create it before `up`: mkdir -p workspace
CALIBAN_WORKSPACE=./workspace

# Log verbosity for all services.
RUST_LOG=info

# ─────────────────────────────────────────────────────────────────────────────
# postgres overlay  (overlays/postgres.yaml)
# ─────────────────────────────────────────────────────────────────────────────
POSTGRES_USER=prospero
POSTGRES_PASSWORD=change-me
POSTGRES_DB=prospero

# ─────────────────────────────────────────────────────────────────────────────
# proxy overlay  (overlays/proxy.yaml)
# ─────────────────────────────────────────────────────────────────────────────
# Public hostname Caddy serves + auto-provisions certs for. Use a real DNS name
# in production; for local testing you can use e.g. prospero.localhost.
DOMAIN=prospero.localhost

# ─────────────────────────────────────────────────────────────────────────────
# network overlay  (overlays/network.yaml) — BETA
# ─────────────────────────────────────────────────────────────────────────────
# Shared bearer token prospero uses to authenticate to caliband over TCP+TLS.
# Generate a strong value, e.g.: openssl rand -hex 32
CALIBAN_DAEMON_TOKEN=
# Port caliband listens on for the TLS control plane (compose-internal).
CALIBAN_DAEMON_PORT=8443
